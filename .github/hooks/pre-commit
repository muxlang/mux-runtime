#!/bin/sh
# Mirrors mux-runtime CI (.github/workflows/ci.yml) rust_checks, minus the heavy
# legs (coverage, valgrind, benchmarks) which stay CI-only. Same spirit as the
# mux-compiler pre-commit: run the fast fmt/clippy/test gate locally, and report
# every failure in one pass instead of stopping at the first.

STAGED_FILES=$(git diff --cached --name-only)

HAS_RUST=false
for file in $STAGED_FILES; do
  case "$file" in
    *.rs|Cargo.toml|Cargo.lock|clippy.toml|rustfmt.toml)
      HAS_RUST=true
      ;;
  esac
done

if [ "$HAS_RUST" = false ]; then
  echo "No Rust files changed, skipping checks."
  exit 0
fi

FAILED=0

echo "Checking Rust formatting..."
if ! cargo fmt --check; then
  echo ""
  echo "Formatting check failed. Run 'cargo fmt' to fix."
  FAILED=1
fi
echo "Formatting OK"

echo ""
echo "Running Clippy (warnings denied)..."
if ! cargo clippy --all-targets --all-features -- -D warnings; then
  echo ""
  echo "Clippy check failed. Fix warnings before committing."
  FAILED=1
fi
echo "Clippy OK"

echo ""
echo "Running tests..."
# --all-features exercises the sql/net drivers; their gated tests skip
# themselves when MUX_TEST_*_URL is unset, so this stays deterministic locally.
if ! cargo test --all-features --workspace; then
  echo ""
  echo "Tests failed. Fix failing tests before committing."
  FAILED=1
fi
echo "Tests OK"

if [ "$FAILED" -ne 0 ]; then
  exit 1
fi
